            "url": {
              "raw": "{{baseUrl}}/api/groups/details?groupId={{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","groups","details"],
              "query": [
                { "key": "groupId", "value": "{{groupId}}" }
              ]
            }
          }
        },
        {
          "name": "Groups By Event",
          "request": {
            "method": "GET",
